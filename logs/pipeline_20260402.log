-- Monthly slim: create isolated medications slim table for this month
-- DDL-only (no DML): CREATE OR REPLACE TABLE creates a standalone per-month table
-- Source: monthly raw staging table medications_2023_11_30
-- JOIN to encounters_slim_2023_11_30 scopes to valid encounters for this month only
CREATE OR REPLACE TABLE hospital-492008.raw_data.medications_slim_2023_11_30
AS
SELECT
  m.start,
  m.stop,
  m.encounter,
  m.code,
  m.description,
  m.base_cost,
  m.dispenses,
  m.totalcost
FROM hospital-492008.raw_data.medications_2023_11_30 m
JOIN hospital-492008.raw_data.encounters_slim_2023_11_30 e
  ON m.encounter = e.id

