      util.total_stay_cost                                   AS total_readmission_cost,
      util.following_unplanned_admission_flag                AS following_unplanned_admission_flag
    FROM window_enc we
    LEFT JOIN hospital-492008.data_slim.patients_slim p
      ON we.patient = p.id
