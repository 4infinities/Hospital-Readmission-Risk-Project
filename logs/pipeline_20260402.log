-- Monthly slim: create isolated careplans slim table for this month
-- DDL-only (no DML): CREATE OR REPLACE TABLE creates a standalone per-month table
-- Source: monthly raw staging table careplans_2023_11_30
-- JOIN to encounters_slim_2023_11_30 scopes to valid encounters for this month only
CREATE OR REPLACE TABLE hospital-492008.raw_data.careplans_slim_2023_11_30
AS
SELECT
  care.Start,
  care.stop,
  care.patient,
  care.encounter,
  care.description,
  care.reasoncode AS code
FROM hospital-492008.raw_data.careplans_2023_11_30 care
JOIN hospital-492008.raw_data.encounters_slim_2023_11_30 e
  ON care.encounter = e.id

