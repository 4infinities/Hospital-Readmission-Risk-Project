-- Monthly slim: create isolated encounters slim table for this month
-- DDL-only (no DML): CREATE OR REPLACE TABLE creates a standalone per-month table
-- Source: monthly raw staging table encounters_2024_09_30
-- Filters: valid encounter classes + alive patients
CREATE OR REPLACE TABLE hospital-492008.raw_data.encounters_slim_2024_09_30
AS
WITH
  p AS (
    SELECT
      id AS patient_id,
      deathdate
    FROM hospital-492008.data_slim.patients_slim
  )
SELECT
  e.id,
  e.start,
  e.stop,
  e.patient,
  e.organization,
  e.encounterclass,
  e.base_encounter_cost,
  e.total_claim_cost,
  e.description
FROM hospital-492008.raw_data.encounters_2024_09_30 e
LEFT JOIN p
  ON e.patient = p.patient_id
WHERE
  e.encounterclass IN (
    'inpatient',
    'emergency',
    'urgentcare',
    'outpatient',
    'ambulatory',
    'virtual',
    'wellness')
  AND e.stop < COALESCE(TIMESTAMP(p.deathdate), TIMESTAMP '9999-12-31')

