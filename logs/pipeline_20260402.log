-- Monthly slim: create isolated conditions slim table for this month
-- DDL-only (no DML): CREATE OR REPLACE TABLE creates a standalone per-month table
-- Source: monthly raw staging table conditions_2024_06_30
-- JOIN to encounters_slim_2024_06_30 scopes to valid encounters for this month only
CREATE OR REPLACE TABLE hospital-492008.raw_data.conditions_slim_2024_06_30
AS
SELECT
  cond.start,
  cond.stop,
  cond.patient,
  cond.encounter,
  cond.code,
  TRIM(SPLIT(cond.description, '(')[OFFSET(0)]) AS diagnosis_name,
  REPLACE(
    TRIM(SPLIT(cond.description, '(')[SAFE_OFFSET(1)]),
    ')',
    '') AS diagnosis_type
FROM hospital-492008.raw_data.conditions_2024_06_30 cond
JOIN hospital-492008.raw_data.encounters_slim_2024_06_30 e
  ON cond.encounter = e.id
WHERE
  COALESCE(
    REPLACE(
      TRIM(SPLIT(cond.description, '(')[SAFE_OFFSET(1)]),
      ')',
      ''))
  != 'situation'

