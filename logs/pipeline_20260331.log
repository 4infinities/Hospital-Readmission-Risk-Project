-- DDL-only (no DML): CREATE OR REPLACE TABLE creates a standalone per-month table
-- Source: monthly raw staging table conditions_2025_08_31
-- JOIN to encounters_slim_2025_08_31 scopes to valid encounters for this month only
CREATE OR REPLACE TABLE healthcare-test-486920.raw_data.conditions_slim_2025_08_31
AS
SELECT
