    LEFT JOIN healthcare-test-486920.data_slim.patients_slim p
      ON we.patient = p.id
    LEFT JOIN healthcare-test-486920.helper_tables.helper_clinical_grouped clin
      ON clin.stay_id = we.id
    LEFT JOIN healthcare-test-486920.helper_tables.helper_cost_aggregation_grouped cost
