-- Monthly slim: create isolated conditions slim table for this month
-- DDL-only (no DML): CREATE OR REPLACE TABLE creates a standalone per-month table
-- Source: monthly raw staging table conditions_2026_03_31
-- JOIN to encounters_slim_2026_03_31 scopes to valid encounters for this month only
CREATE OR REPLACE TABLE healthcare-test-486920.raw_data.conditions_slim_2026_03_31
AS
SELECT
  cond.start,
  cond.stop,
  cond.patient,
  cond.encounter,
  cond.code,
  TRIM(SPLIT(cond.description, '(')[OFFSET(0)]) AS diagnosis_name,
  REPLACE(
    TRIM(SPLIT(cond.description, '(')[SAFE_OFFSET(1)]),
    ')',
    '') AS diagnosis_type
FROM healthcare-test-486920.raw_data.conditions_2026_03_31 cond
