    LEFT JOIN healthcare-test-486920.helper_tables.helper_utilization util
      ON util.stay_id = we.id
    LEFT JOIN healthcare-test-486920.helper_tables.related_diagnoses rel
      ON we.id = rel.stay_id
  )
