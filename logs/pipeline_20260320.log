-- Slim careplans: inner join to encounters_slim to retain only careplans linked to valid encounters
CREATE OR REPLACE TABLE healthcare-test-486920.data_slim.careplans_slim
  PARTITION BY DATE_TRUNC(stop, MONTH)
  CLUSTER BY patient, encounter
AS
SELECT
  care.Start,
  care.stop,
  care.patient,
  care.encounter,
  care.description,
  care.reasoncode as code
FROM healthcare-test-486920.raw_data.careplans care
-- Only keep careplans whose triggering encounter passed the encounters_slim filters
JOIN healthcare-test-486920.data_slim.encounters_slim e
  ON care.encounter = e.id
