-- Slim patients: retain only demographic columns needed downstream; cluster by id for join performance
CREATE OR REPLACE TABLE healthcare-test-486920.data_slim.patients_slim
  CLUSTER BY id
AS
SELECT
  id,
  birthdate,
  deathdate,
  race,
  gender
FROM healthcare-test-486920.raw_data.patients
