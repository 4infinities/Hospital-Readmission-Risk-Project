-- Monthly append: new month's careplans into careplans_slim
-- DDL-only (no DML): CREATE OR REPLACE preserves existing rows via UNION ALL
-- Source: monthly raw staging table careplans_2025_05_31
-- JOIN to encounters_2025_05_31 scopes to valid encounters for this month only
CREATE OR REPLACE TABLE healthcare-test-486920.data_slim.careplans_slim
  CLUSTER BY patient, encounter
AS
SELECT
  Start,
  stop,
  patient,
  encounter,
  description,
  code
FROM healthcare-test-486920.data_slim.careplans_slim
UNION ALL
SELECT
  care.Start,
  care.stop,
  care.patient,
  care.encounter,
  care.description,
  care.reasoncode AS code
FROM healthcare-test-486920.raw_data.careplans_2025_05_31 care
JOIN healthcare-test-486920.raw_data.encounters_2025_05_31 e
  ON care.encounter = e.id

